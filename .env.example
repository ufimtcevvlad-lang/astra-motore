TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
YANDEX_METRIKA_OAUTH_TOKEN=
YANDEX_METRIKA_COUNTER_ID=108384071
REPORT_TIMEZONE=Asia/Yekaterinburg

# Cloudflare Turnstile (optional)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# CDEK API integration
# Production: https://api.cdek.ru/v2
# Test: https://api.edu.cdek.ru/v2
CDEK_API_BASE_URL=https://api.cdek.ru/v2
CDEK_CLIENT_ID=
CDEK_CLIENT_SECRET=

# CDEK city code of shipment origin (warehouse city).
# Example: 44 is Moscow. Set your actual warehouse code.
CDEK_FROM_LOCATION_CODE=

# Approximate shipment model for quick checkout estimate
CDEK_WEIGHT_PER_ITEM_GRAMS=800
## Telegram (уже используется для заказов)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

## Yandex Metrika API
YANDEX_METRIKA_OAUTH_TOKEN=
YANDEX_METRIKA_COUNTER_ID=108384071
# Тот же ID для счётчика на сайте (подставляется при next build)
NEXT_PUBLIC_YANDEX_METRIKA_ID=108384071

## Optional: timezone for daily report date
REPORT_TIMEZONE=Europe/Moscow
NEXT_PUBLIC_SITE_URL=https://gmshop66.ru

## SMS.ru (для SMS-входа)
SMSRU_API_ID=
SMSRU_SENDER=
# Telegram: заказы будут приходить сюда.
# Создай бота через @BotFather в Telegram, получи токен.
# Узнай свой Chat ID: напиши боту /start, затем открой в браузере:
# https://api.telegram.org/bot<ТВОЙ_ТОКЕН>/getUpdates — в ответе будет "chat":{"id":123456789}

TELEGRAM_BOT_TOKEN=123456:ABCdefGHI...
TELEGRAM_CHAT_ID=123456789
