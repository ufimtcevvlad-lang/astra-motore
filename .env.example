# Скопируйте в .env.local и заполните значения.

# Публичный URL сайта (canonical, SEO, ссылки)
NEXT_PUBLIC_SITE_URL=https://gmshop66.ru

# Telegram: заказы и уведомления
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Яндекс.Метрика: тот же номер счётчика в обеих строках; OAuth — для API / cron (metrika:daily, бот)
NEXT_PUBLIC_YANDEX_METRIKA_ID=108384071
YANDEX_METRIKA_COUNTER_ID=108384071
YANDEX_METRIKA_OAUTH_TOKEN=

# Часовой пояс для отчётов (cron)
REPORT_TIMEZONE=Asia/Yekaterinburg

# Cloudflare Turnstile (опционально)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# CDEK: доставка
CDEK_API_BASE_URL=https://api.cdek.ru/v2
CDEK_CLIENT_ID=
CDEK_CLIENT_SECRET=
CDEK_FROM_LOCATION_CODE=
CDEK_WEIGHT_PER_ITEM_GRAMS=800

# SMS.ru — вход по SMS
SMSRU_API_ID=
SMSRU_SENDER=

# Режим обслуживания (опционально)
# MAINTENANCE_MODE=1
# MAINTENANCE_MESSAGE=Ведутся работы по улучшению сайта.
