# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# выгрузки каталога (npm run catalog:export-xlsx)
/exports/

# misc
.DS_Store
*.pem

# Python (скрипты в scripts/)
__pycache__/
*.py[cod]

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
