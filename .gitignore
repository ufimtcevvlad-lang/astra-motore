# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# drizzle migrations — committed, needed for deployment
# drizzle/

# SQLite database files
data/shop.db
data/shop.db-wal
data/shop.db-shm
.worktrees/
.claude/worktrees/
